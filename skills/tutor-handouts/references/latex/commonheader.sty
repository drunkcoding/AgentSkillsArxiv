% commonheader.sty — shared typography, palette, listings, fancyhdr for tutor-handouts
% Generated by tutor-handouts. Copied to Coursepack/Handouts/_common/.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{commonheader}[2026/05/17 v1.0 shared header for tutor-handouts]

% ---------------------------------------------------------------------------
% Fonts and encoding (no commercial fonts; lmodern only — INV-2)
% ---------------------------------------------------------------------------
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage{lmodern}
\RequirePackage{microtype}

% ---------------------------------------------------------------------------
% Math
% ---------------------------------------------------------------------------
\RequirePackage{amsmath}
\RequirePackage{amsthm}
\RequirePackage{amssymb}
\RequirePackage{mathtools}

% ---------------------------------------------------------------------------
% Page geometry — 1 inch margins, US letter
% ---------------------------------------------------------------------------
\RequirePackage[letterpaper,top=1in,bottom=1in,left=1in,right=1in]{geometry}

% ---------------------------------------------------------------------------
% Palette
% ---------------------------------------------------------------------------
\RequirePackage[table]{xcolor}
% Palette swap: skill rewrites \selectedpalette at TH2 to one of:
%   generic-blue (default), cmu-red, stanford-cardinal, mit-cardinal, berkeley-blue
\providecommand{\selectedpalette}{generic-blue}

% Each palette defines: \accentcolor (primary), \accentdark (titles), \accentlight (boxes)
\definecolor{generic-blue-accent}{RGB}{28,69,135}
\definecolor{generic-blue-dark}{RGB}{14,40,90}
\definecolor{generic-blue-light}{RGB}{220,230,245}

\definecolor{cmu-red-accent}{RGB}{198,12,48}
\definecolor{cmu-red-dark}{RGB}{125,0,32}
\definecolor{cmu-red-light}{RGB}{250,228,232}

\definecolor{stanford-cardinal-accent}{RGB}{140,21,21}
\definecolor{stanford-cardinal-dark}{RGB}{85,0,0}
\definecolor{stanford-cardinal-light}{RGB}{247,228,228}

\definecolor{mit-cardinal-accent}{RGB}{163,31,52}
\definecolor{mit-cardinal-dark}{RGB}{105,0,16}
\definecolor{mit-cardinal-light}{RGB}{248,225,229}

\definecolor{berkeley-blue-accent}{RGB}{0,50,98}
\definecolor{berkeley-blue-dark}{RGB}{0,25,55}
\definecolor{berkeley-blue-light}{RGB}{223,232,243}

% Resolve palette to working colors
\colorlet{accentcolor}{generic-blue-accent}
\colorlet{accentdark}{generic-blue-dark}
\colorlet{accentlight}{generic-blue-light}

\AtBeginDocument{%
  \expandafter\colorlet\expandafter{accentcolor}{\selectedpalette-accent}%
  \expandafter\colorlet\expandafter{accentdark}{\selectedpalette-dark}%
  \expandafter\colorlet\expandafter{accentlight}{\selectedpalette-light}%
}

% ---------------------------------------------------------------------------
% Code listings (listings, NOT minted — INV-3)
% ---------------------------------------------------------------------------
\RequirePackage{listings}
\lstdefinelanguage{CUDA}{
  morekeywords={__global__, __device__, __host__, __shared__, __constant__,
    __syncthreads, __syncwarp, blockIdx, threadIdx, blockDim, gridDim, warpSize,
    cudaMalloc, cudaMemcpy, cudaFree, cudaDeviceSynchronize, cudaError_t,
    cudaSuccess, cudaGetLastError, cudaMemcpyHostToDevice, cudaMemcpyDeviceToHost,
    atomicAdd, atomicCAS, atomicExch},
  sensitive=true,
  morecomment=[l]{//},
  morecomment=[s]{/*}{*/},
  morestring=[b]",
  alsoletter={\#},
  alsodigit={\#}
}
\lstdefinelanguage{Triton}{
  morekeywords={import, from, def, return, if, else, for, while, class, with,
    triton, tl, jit, autotune, Config, heuristics, constexpr, program_id,
    arange, load, store, dot, exp, log, max, sum, where, zeros, full, make_block_ptr,
    advance, atomic_add, atomic_cas, atomic_xchg, num_warps, num_stages, BLOCK_SIZE},
  sensitive=true,
  morecomment=[l]{\#},
  morestring=[b]",
  morestring=[b]'
}
\lstset{
  basicstyle=\ttfamily\small,
  keywordstyle=\bfseries\color{accentdark},
  commentstyle=\itshape\color{gray},
  stringstyle=\color{accentcolor},
  numbers=left,
  numberstyle=\tiny\color{gray},
  numbersep=8pt,
  tabsize=4,
  showstringspaces=false,
  breaklines=true,
  breakatwhitespace=true,
  frame=single,
  rulecolor=\color{black!30},
  framesep=4pt,
  xleftmargin=1.5em,
  captionpos=b,
  belowcaptionskip=0.5em,
  aboveskip=1em,
  belowskip=1em
}
\providecommand{\code}[1]{\lstinline|#1|}

% ---------------------------------------------------------------------------
% Header / footer (fancyhdr)
% ---------------------------------------------------------------------------
\RequirePackage{fancyhdr}
\RequirePackage{lastpage}
\setlength{\headheight}{24pt}
\setlength{\headsep}{16pt}

% Metadata (filled by .cls subclasses)
\providecommand{\@coursename}{Course Name}
\providecommand{\@courseterm}{Term}
\providecommand{\@handoutnumber}{0}
\providecommand{\@handouttitle}{Untitled Handout}
\providecommand{\@duedate}{TBD}
\providecommand{\@assignmentauthors}{Course Staff}

\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\small\color{accentdark}\@coursename\quad\textbar\quad\@courseterm}
\fancyhead[R]{\small\color{accentdark}Handout \@handoutnumber: \@handouttitle}
\fancyfoot[C]{\small \thepage\ of \pageref{LastPage}}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\headrule}{\hbox to\headwidth{\color{accentcolor}\leaders\hrule height \headrulewidth\hfill}}
\renewcommand{\footrulewidth}{0pt}

% ---------------------------------------------------------------------------
% Tables (booktabs)
% ---------------------------------------------------------------------------
\RequirePackage{booktabs}
\RequirePackage{array}
\RequirePackage{tabularx}

% ---------------------------------------------------------------------------
% Lists (enumitem)
% ---------------------------------------------------------------------------
\RequirePackage{enumitem}
\setlist{nosep,leftmargin=1.5em}

% ---------------------------------------------------------------------------
% Hyperref (last)
% ---------------------------------------------------------------------------
\RequirePackage[hidelinks,
  colorlinks=true,
  linkcolor=accentdark,
  urlcolor=accentcolor,
  citecolor=accentcolor,
  pdfborder={0 0 0}]{hyperref}

% ---------------------------------------------------------------------------
% Anti-AI-slop section header style — accent rule under section titles
% ---------------------------------------------------------------------------
\RequirePackage{titlesec}
\titleformat{\section}
  {\Large\bfseries\color{accentdark}}
  {\thesection}{0.5em}{}
  [\vspace{-0.4em}{\color{accentcolor}\rule{\linewidth}{0.4pt}}]
\titleformat{\subsection}
  {\large\bfseries\color{accentdark}}
  {\thesubsection}{0.5em}{}

\endinput
