% cheatsheet.cls — H2 landscape 2-column cheatsheet
% Generated by tutor-handouts. Copied to Coursepack/Handouts/_common/.
\NeedsTeXFormat{LaTeX2e}
\ProvidesClass{cheatsheet}[2026/05/17 v1.0 tutor-handouts cheatsheet]

\DeclareOption*{\PassOptionsToClass{\CurrentOption}{article}}
\ProcessOptions\relax

\LoadClass[9pt,landscape,letterpaper]{extarticle}

% Override geometry for tight margins BEFORE commonheader loads it
\PassOptionsToPackage{landscape,letterpaper,top=0.4in,bottom=0.4in,left=0.4in,right=0.4in}{geometry}

\RequirePackage{commonheader}

% Re-apply geometry (commonheader's geometry was the 1in default; we override)
\geometry{landscape,letterpaper,top=0.4in,bottom=0.4in,left=0.4in,right=0.4in}

\RequirePackage{multicol}
\setlength{\columnsep}{1em}
\setlength{\columnseprule}{0.2pt}
\renewcommand{\columnseprulecolor}{\color{accentcolor}}

% Metadata setters (cheatsheets still need course/title even without fancyhdr)
\newcommand{\coursename}[1]{\renewcommand{\@coursename}{#1}}
\newcommand{\courseterm}[1]{\renewcommand{\@courseterm}{#1}}
\newcommand{\handoutnumber}[1]{\renewcommand{\@handoutnumber}{#1}}
\newcommand{\handouttitle}[1]{\renewcommand{\@handouttitle}{#1}}

% No fancyhdr on cheatsheets — pure content
\pagestyle{empty}

% Tighter section titles
\titleformat{\section}
  {\large\bfseries\color{accentdark}}
  {}{0pt}{}
  [\vspace{-0.5em}{\color{accentcolor}\rule{\linewidth}{0.3pt}}]
\titleformat{\subsection}
  {\normalsize\bfseries\color{accentdark}}
  {}{0pt}{}
\titlespacing*{\section}{0pt}{0.4em}{0.2em}
\titlespacing*{\subsection}{0pt}{0.3em}{0.1em}

% Tighter lists
\setlist{nosep,leftmargin=1.2em,topsep=0pt}

% Cheatsheet title — top-left only, no centered banner
\renewcommand{\maketitle}{%
  \noindent{\Large\bfseries\color{accentdark}\@handouttitle}\hfill%
  {\small\color{accentdark}\@coursename\ \textbar\ \@courseterm}\par%
  \vspace{0.2em}%
  {\color{accentcolor}\rule{\linewidth}{0.5pt}}%
  \par\vspace{0.4em}%
}

\endinput
