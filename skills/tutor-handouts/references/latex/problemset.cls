% problemset.cls — H4 short-answer / multiple-choice problem set
% Generated by tutor-handouts. Copied to Coursepack/Handouts/_common/.
\NeedsTeXFormat{LaTeX2e}
\ProvidesClass{problemset}[2026/05/17 v1.0 tutor-handouts problem set]

\DeclareOption*{\PassOptionsToClass{\CurrentOption}{article}}
\ProcessOptions\relax

\LoadClass[11pt,letterpaper]{article}
\RequirePackage{commonheader}

% Metadata setters (mirror handout.cls)
\newcommand{\coursename}[1]{\renewcommand{\@coursename}{#1}}
\newcommand{\courseterm}[1]{\renewcommand{\@courseterm}{#1}}
\newcommand{\handoutnumber}[1]{\renewcommand{\@handoutnumber}{#1}}
\newcommand{\handouttitle}[1]{\renewcommand{\@handouttitle}{#1}}
\newcommand{\duedate}[1]{\renewcommand{\@duedate}{#1}}

% Title banner — compact for problem sets
\renewcommand{\maketitle}{%
  \begin{center}
    {\Large\bfseries\color{accentdark}\@coursename\par}
    \vspace{0.2em}
    {\LARGE\bfseries\@handouttitle\par}
    \vspace{0.2em}
    {\normalsize\color{accentdark}Problem Set \@handoutnumber \quad\textbar\quad \@courseterm\par}
    \vspace{0.3em}
    {\color{accentcolor}\rule{0.6\linewidth}{0.4pt}}
  \end{center}
  \vspace{0.6em}
}

% Solution switch
\newif\ifsolution\solutionfalse

% Problem counter and \problem{title}[points]
\newcounter{problemcounter}
\newcommand{\problem}[2][]{%
  \refstepcounter{problemcounter}%
  \vspace{0.8em}%
  \par\noindent\textbf{\color{accentdark}Problem \arabic{problemcounter}.\ #2}%
  \ifx\\#1\\\else\hfill\textbf{[\textcolor{accentcolor}{#1 pts}]}\fi%
  \par\nobreak\vspace{0.2em}%
}

% \answerbox{height-in-inches} — blank rule for handwritten short answers
\newcommand{\answerbox}[1]{%
  \par\medskip%
  \framebox[\linewidth][l]{\rule{0pt}{#1in}}%
  \par\medskip%
}

% \mcq{a}{b}{c}{d}{correct=letter}
% In student mode: prints the 4 options.
% In solution mode: bolds and highlights the correct one.
\newcommand{\mcq}[5]{%
  \par\medskip%
  \begin{itemize}[leftmargin=2em,nosep]%
    \item[(A)] \mcqitem{A}{#5}{#1}%
    \item[(B)] \mcqitem{B}{#5}{#2}%
    \item[(C)] \mcqitem{C}{#5}{#3}%
    \item[(D)] \mcqitem{D}{#5}{#4}%
  \end{itemize}%
  \par\medskip%
}

\newcommand{\mcqitem}[3]{%
  \ifsolution%
    \ifx\detokenize{#1}\detokenize{#2}%
      \textbf{\color{accentdark}#3\ \(\leftarrow\) correct}%
    \else%
      #3%
    \fi%
  \else%
    #3%
  \fi%
}

% Solution-only block. Use a deferred-collection approach so that we can
% silently drop the content without exposing inner braces to balance checks
% (which the `comment` package would do but can choke inside other envs).
\RequirePackage{environ}
\NewEnviron{solutionbox}{%
  \ifsolution
    \par\medskip\noindent\fbox{\begin{minipage}{\dimexpr\linewidth-2\fboxsep-2\fboxrule\relax}%
      \textbf{\color{accentdark}Answer.}\par\nobreak\vspace{0.2em}%
      \BODY
    \end{minipage}}\par\medskip%
  \fi
}

\endinput
