% handout.cls — base class for H1 (lecture), H3 (programming assignment), H5 (capstone)
% Generated by tutor-handouts. Copied to Coursepack/Handouts/_common/.
\NeedsTeXFormat{LaTeX2e}
\ProvidesClass{handout}[2026/05/17 v1.0 tutor-handouts course handout]

\newif\if@handout@lecture\@handout@lecturetrue
\newif\if@handout@programming\@handout@programmingfalse
\newif\if@handout@capstone\@handout@capstonefalse

\DeclareOption{lecture}{%
  \@handout@lecturetrue\@handout@programmingfalse\@handout@capstonefalse}
\DeclareOption{programming}{%
  \@handout@lecturefalse\@handout@programmingtrue\@handout@capstonefalse}
\DeclareOption{capstone}{%
  \@handout@lecturefalse\@handout@programmingfalse\@handout@capstonetrue}

\DeclareOption*{\PassOptionsToClass{\CurrentOption}{article}}
\ProcessOptions\relax

\LoadClass[11pt,letterpaper]{article}
\RequirePackage{commonheader}

% ---------------------------------------------------------------------------
% Metadata setters (used by the .tex preamble)
% ---------------------------------------------------------------------------
\newcommand{\coursename}[1]{\renewcommand{\@coursename}{#1}}
\newcommand{\courseterm}[1]{\renewcommand{\@courseterm}{#1}}
\newcommand{\handoutnumber}[1]{\renewcommand{\@handoutnumber}{#1}}
\newcommand{\handouttitle}[1]{\renewcommand{\@handouttitle}{#1}}
\newcommand{\duedate}[1]{\renewcommand{\@duedate}{#1}}
\newcommand{\assignmentauthors}[1]{\renewcommand{\@assignmentauthors}{#1}}

% ---------------------------------------------------------------------------
% Title banner — three centered lines
% ---------------------------------------------------------------------------
\renewcommand{\maketitle}{%
  \begin{center}
    {\Large\bfseries\color{accentdark}\@coursename\par}
    \vspace{0.3em}
    {\Huge\bfseries\@handouttitle\par}
    \vspace{0.5em}
    \if@handout@programming
      {\large\color{accentdark}Programming Assignment \@handoutnumber\par}
      \vspace{0.2em}
      {\normalsize\textbf{Due:} \@duedate \quad\textbar\quad \textbf{Term:} \@courseterm\par}
    \else
      \if@handout@capstone
        {\large\color{accentdark}Capstone Project\par}
        \vspace{0.2em}
        {\normalsize\textbf{Term:} \@courseterm\par}
      \else
        {\large\color{accentdark}Lecture Handout \@handoutnumber\par}
        \vspace{0.2em}
        {\normalsize\textbf{Term:} \@courseterm\par}
      \fi
    \fi
    \vspace{0.3em}
    {\color{accentcolor}\rule{0.7\linewidth}{0.6pt}}
  \end{center}
  \vspace{0.8em}
}

% ---------------------------------------------------------------------------
% Solution-aware switch (used by solution.cls)
% ---------------------------------------------------------------------------
\newif\ifsolution
\solutionfalse

% ---------------------------------------------------------------------------
% Programming-assignment environments (active when option=programming)
% ---------------------------------------------------------------------------
\newcounter{taskpartcounter}

% \taskpart{name}{points}
\newcommand{\taskpart}[2]{%
  \refstepcounter{taskpartcounter}%
  \vspace{0.8em}%
  \noindent\textbf{\color{accentdark}Part \arabic{taskpartcounter}: #1}%
  \hfill\textbf{[\textcolor{accentcolor}{#2 pts}]}%
  \par\nobreak\vspace{0.2em}%
}

% Starter-file box: header + code listing
\newenvironment{starterbox}[1]{%
  \par\medskip%
  \noindent\fcolorbox{accentcolor}{accentlight}{%
    \begin{minipage}{\dimexpr\linewidth-2\fboxsep-2\fboxrule\relax}%
      \textbf{File:} \texttt{#1}%
    \end{minipage}}%
  \par\nobreak\vspace{0.2em}%
}{\par\medskip}

% Deliverable shaded box
\newenvironment{deliverable}{%
  \par\medskip%
  \begin{tcb@simple}%
}{%
  \end{tcb@simple}%
}

% Simple shaded box without external dep (uses xcolor only)
\newenvironment{tcb@simple}{%
  \par\noindent\begingroup\color{accentdark}\textbf{Submit:}\quad\ignorespaces%
}{\par\endgroup\medskip}

% Rubric table is a plain booktabs table; we just provide a wrapper
\newenvironment{rubricbox}{%
  \par\medskip\noindent\textbf{\color{accentdark}Grading Rubric}\par\nobreak\vspace{0.2em}%
}{\par\medskip}

% Solution-only blocks (rendered only when \ifsolution).
% Uses environ's \BODY mechanism so we can silently drop content
% without exposing inner braces to comment-style balance checks
% (which choke when called from inside other custom envs).
\RequirePackage{environ}
\NewEnviron{solutiononly}{%
  \ifsolution
    \par\medskip\noindent\textbf{\color{accentdark}Solution.}\par\nobreak
    \BODY
    \par\medskip
  \fi
}

\endinput
