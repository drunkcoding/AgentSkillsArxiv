% solution.cls — instructor-only variant of handout.cls / problemset.cls
% Generated by tutor-handouts. Copied to Coursepack/Handouts/_common/.
%
% Usage:
%   \documentclass[programming]{solution}     % H3 with solutions visible
%   \documentclass[problemset]{solution}       % H4 with answer keys visible
\NeedsTeXFormat{LaTeX2e}
\ProvidesClass{solution}[2026/05/17 v1.0 tutor-handouts solution variant]

\newif\if@sol@problemset\@sol@problemsetfalse

\DeclareOption{problemset}{\@sol@problemsettrue}
\DeclareOption*{\PassOptionsToClass{\CurrentOption}{handout}}
\ProcessOptions\relax

\if@sol@problemset
  \LoadClass{problemset}
\else
  \LoadClass[programming]{handout}
\fi

% Activate solution rendering
\AtBeginDocument{\solutiontrue}

\endinput
